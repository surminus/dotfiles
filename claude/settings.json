{
  "permissions": {
    "allow": [
      "Bash(awk:*)",
      "Bash(bundle:*)",
      "Bash(cat:*)",
      "Bash(curl:*)",
      "Bash(docker:*)",
      "Bash(find:*)",
      "Bash(gh:*)",
      "Bash(git:*)",
      "Bash(go:*)",
      "Bash(gofmt:*)",
      "Bash(goimports:*)",
      "Bash(golangci-lint:*)",
      "Bash(grep:*)",
      "Bash(hcl2json:*)",
      "Bash(jq:*)",
      "Bash(jsonnet:*)",
      "Bash(ls:*)",
      "Bash(make:*)",
      "Bash(mise:*)",
      "Bash(npm:*)",
      "Bash(python3:*)",
      "Bash(rg:*)",
      "Bash(sed:*)",
      "Bash(shellcheck:*)",
      "Bash(wc:*)",
      "WebFetch(domain:*)",
      "WebSearch"
    ],
    "additionalDirectories": [
      "~/claude"
    ]
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "effortLevel": "high",
  "autoUpdatesChannel": "latest",
  "skipWorkflowUsageWarning": true
}
